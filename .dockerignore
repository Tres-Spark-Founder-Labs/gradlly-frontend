# =============================================================================
# GRADLLY — .dockerignore
# Applies to all Docker builds across the monorepo
# =============================================================================

# -----------------------------------------------------------------------------
# Version control
# -----------------------------------------------------------------------------
.git/
.gitignore
.gitattributes

# -----------------------------------------------------------------------------
# Dependencies — reinstalled inside container
# -----------------------------------------------------------------------------
node_modules/
**/node_modules/
.pnp
.pnp.js

# -----------------------------------------------------------------------------
# Build outputs — rebuilt inside container
# -----------------------------------------------------------------------------
.next/
**/.next/
out/
**/out/
dist/
**/dist/
build/
**/build/

# -----------------------------------------------------------------------------
# Environment — injected at runtime, never baked into image
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
**/.env
**/.env.local
**/.env.*.local

# .env.example is safe to include — it has no real values
# .env.development and .env.production safe if they hold no secrets

# -----------------------------------------------------------------------------
# Turbo cache — not needed in image
# -----------------------------------------------------------------------------
.turbo/
**/.turbo/

# -----------------------------------------------------------------------------
# TypeScript build info
# -----------------------------------------------------------------------------
*.tsbuildinfo
**/tsconfig.tsbuildinfo

# -----------------------------------------------------------------------------
# Testing — never in production image
# -----------------------------------------------------------------------------
coverage/
**/coverage/
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
**/__tests__/
**/__mocks__/
**/e2e/
playwright-report/
test-results/

# -----------------------------------------------------------------------------
# Storybook
# -----------------------------------------------------------------------------
storybook-static/
**/storybook-static/
**/.storybook/

# -----------------------------------------------------------------------------
# IDE and editors
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
.history/

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
Thumbs.db
desktop.ini
._*

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*

# -----------------------------------------------------------------------------
# Docker — don't copy docker files into themselves
# -----------------------------------------------------------------------------
Dockerfile
Dockerfile.*
docker-compose*.yml
.dockerignore

# -----------------------------------------------------------------------------
# CI/CD config — not needed at runtime
# -----------------------------------------------------------------------------
.github/
.gitlab-ci.yml
.circleci/
.husky/
.eslintcache

# -----------------------------------------------------------------------------
# Docs and non-runtime files
# -----------------------------------------------------------------------------
README.md
**/README.md
CHANGELOG.md
**/CHANGELOG.md
LICENSE
docs/
*.md

# AI agent files
AGENTS.md
CLAUDE.md
**/AGENTS.md
**/CLAUDE.md

# -----------------------------------------------------------------------------
# Package manager debug
# -----------------------------------------------------------------------------
.npm/
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -----------------------------------------------------------------------------
# Secrets and certificates — absolute hard exclusion
# -----------------------------------------------------------------------------
*.pem
*.key
*.cert
*.p12
*.pfx
.sentryclirc
secrets/
**/secrets/
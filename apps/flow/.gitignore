# =============================================================================
# GRADLLY APP-LEVEL .gitignore
# Applied to: apps/employer, apps/provider, apps/apprentice, apps/flow, apps/main
# =============================================================================

# -----------------------------------------------------------------------------
# Next.js
# -----------------------------------------------------------------------------
.next/
out/
build/

# Next.js cache
.next/cache/

# Next.js types (auto-generated, not for VCS)
next-env.d.ts

# -----------------------------------------------------------------------------
# Environment variables
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# -----------------------------------------------------------------------------
# Dependencies (hoisted to root in monorepo, but guard here too)
# -----------------------------------------------------------------------------
node_modules/

# -----------------------------------------------------------------------------
# TypeScript
# -----------------------------------------------------------------------------
*.tsbuildinfo
tsconfig.tsbuildinfo

# -----------------------------------------------------------------------------
# Turbo
# -----------------------------------------------------------------------------
.turbo/

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
test-results/
playwright-report/
playwright/.cache/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
npm-debug.log*

# -----------------------------------------------------------------------------
# Vercel
# -----------------------------------------------------------------------------
.vercel/

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# PWA (apprentice portal — auto-generated service worker files)
# -----------------------------------------------------------------------------
public/sw.js
public/sw.js.map
public/workbox-*.js
public/workbox-*.js.map
public/worker-*.js
public/worker-*.js.map
public/fallback-*.js
public/fallback-*.js.map

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.pem
.cache/
tmp/
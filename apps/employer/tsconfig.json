{
  "extends": "@gradlly/config/typescript/next.json",
  "compilerOptions": {
    "baseUrl": ".",
    "noEmit": true,
    "paths": {
      "@/*": ["./*"],
      "@gradlly/ui": ["../../packages/ui/src/index.ts"],
      "@gradlly/utils": ["../../packages/utils/src/index.ts"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}

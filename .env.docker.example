# .env.docker

# ─── Environment ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_ENV=development

# ─── API URLs ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://api.gradlly.local
INTERNAL_API_URL=http://host.docker.internal:8000

# ─── Portal URLs ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_MAIN_URL=http://main.gradlly.local
NEXT_PUBLIC_EMPLOYER_URL=http://employer.gradlly.local
NEXT_PUBLIC_PROVIDER_URL=http://provider.gradlly.local
NEXT_PUBLIC_APPRENTICE_URL=http://apprentice.gradlly.local
NEXT_PUBLIC_FLOW_URL=http://flow.gradlly.local

# ─── Internal ports (used by Docker services, not exposed to host) ────────────
PORT_MAIN=3000
PORT_EMPLOYER=3002
PORT_PROVIDER=3004
PORT_APPRENTICE=3001
PORT_FLOW=3003
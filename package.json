{
  "name": "gradlly",
  "private": true,
  "scripts": {
    "dev": "turbo run dev --filter=./apps/* --output-logs=full",
    "dev:employer": "turbo run dev --filter=@gradlly/employer",
    "dev:provider": "turbo run dev --filter=@gradlly/provider",
    "dev:apprentice": "turbo run dev --filter=@gradlly/apprentice",
    "dev:flow": "turbo run dev --filter=@gradlly/flow",
    "check-types": "turbo run check-types",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,md,json,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,md,json,css}\"",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "prettier": "^3.7.4",
    "turbo": "^2.9.5",
    "typescript": "5.9.2",
    "typescript-eslint": "^8.58.1"
  },
  "engines": {
    "node": ">=20",
    "npm": ">=9"
  },
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}

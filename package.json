{
  "name": "gradlly",
  "private": true,
  "scripts": {
    "dev": "turbo run dev --filter=./apps/* --output-logs=full",
    "dev:employer": "turbo run dev --filter=@gradlly/employer",
    "dev:provider": "turbo run dev --filter=@gradlly/provider",
    "dev:apprentice": "turbo run dev --filter=@gradlly/apprentice",
    "dev:flow": "turbo run dev --filter=@gradlly/flow",
    "check-types": "turbo run check-types",
    "build": "turbo run build",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,css}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "husky install",
    "dev:main": "turbo run dev --filter=@gradlly/main",
    "dead-code": "ts-prune"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "prettier": "^3.7.4",
    "turbo": "^2.9.5",
    "typescript": "5.9.2",
    "eslint": "^9.38.0",
    "@eslint/js": "^9.38.0",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-config-next": "^16.2.2",
    "@next/eslint-plugin-next": "^16.2.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.4"
  },
  "engines": {
    "node": ">=20",
    "npm": ">=9"
  },
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}

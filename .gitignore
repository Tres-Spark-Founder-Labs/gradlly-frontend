# =============================================================================
# GRADLLY MONOREPO — ROOT .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# -----------------------------------------------------------------------------
# Turbo
# -----------------------------------------------------------------------------
.turbo/
**/.turbo/

# -----------------------------------------------------------------------------
# Build outputs
# -----------------------------------------------------------------------------
dist/
build/
out/
.next/
**/.next/
**/dist/
**/build/
**/out/

# -----------------------------------------------------------------------------
# Environment variables — NEVER commit these
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# Safe to commit (no secrets, only keys with empty values)
# .env.example     ← keep this
# .env.development ← keep this (no real secrets)
# .env.production  ← keep this (no real secrets)

# -----------------------------------------------------------------------------
# Package manager
# -----------------------------------------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
.npmrc.local

# -----------------------------------------------------------------------------
# TypeScript
# -----------------------------------------------------------------------------
*.tsbuildinfo
tsconfig.tsbuildinfo
**/tsconfig.tsbuildinfo

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
coverage/
**/coverage/
.nyc_output/
**/.nyc_output/
test-results/
playwright-report/
playwright/.cache/

# -----------------------------------------------------------------------------
# IDE and editors
# -----------------------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.swp
*.swo
*~
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.history/

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
.docker/
docker-compose.override.yml

# -----------------------------------------------------------------------------
# Vercel
# -----------------------------------------------------------------------------
.vercel/

# -----------------------------------------------------------------------------
# Sentry (if added later)
# -----------------------------------------------------------------------------
.sentryclirc

# -----------------------------------------------------------------------------
# Storybook (if added later)
# -----------------------------------------------------------------------------
storybook-static/
**/storybook-static/

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.pem
*.key
*.cert
*.p12
*.pfx
.cache/
**/.cache/
tmp/
temp/
.temp/
*.tmp

# AI agent files — never ship these
AGENTS.md
CLAUDE.md
**/AGENTS.md
**/CLAUDE.md

.doc